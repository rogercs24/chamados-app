# ==========================================================================
# Variáveis de ambiente — copie para .env e ajuste. NUNCA commite o .env real.
# Cada app também tem seu próprio .env.example; este documenta o stack todo.
# ==========================================================================

# --- Banco de dados (MySQL) ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=chamados
MYSQL_USER=chamados
MYSQL_PASSWORD=chamados
# String de conexão usada pelo Prisma (apps/api)
DATABASE_URL="mysql://chamados:chamados@localhost:3306/chamados"

# --- Redis (cache, filas BullMQ, adapter do Socket.IO) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=3333
NODE_ENV=development

# --- JWT / Auth ---
JWT_ACCESS_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_REFRESH_SECRET=troque-por-outro-segredo-longo-e-aleatorio
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# --- OAuth Google (Fase 1) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3333/api/auth/google/callback

# --- OAuth GitHub (Fase 1) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3333/api/auth/github/callback

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3333

# --- E-mail (dev usa Mailhog) ---
SMTP_HOST=localhost
SMTP_PORT=1025

# --- Observabilidade (Sentry) — opcional; sem DSN a integração fica desligada ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
